# =============================================================================
# LKB Jewellers - Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values
# cp .env.example .env.local
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase
# Dashboard: https://supabase.com/dashboard/project/YOUR_PROJECT_REF/settings/api
# Docs: https://supabase.com/docs/guides/getting-started/quickstarts/nextjs
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# -----------------------------------------------------------------------------
# Admin Dashboard
# Used for /dashboard admin login
# -----------------------------------------------------------------------------
ADMIN_PASSWORD=change-this-to-a-strong-password

# -----------------------------------------------------------------------------
# Stripe (Payment Processing)
# Dashboard: https://dashboard.stripe.com/apikeys
# Docs: https://docs.stripe.com/checkout/quickstart
# -----------------------------------------------------------------------------
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_or_pk_test_xxx
STRIPE_SECRET_KEY=sk_live_or_sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# -----------------------------------------------------------------------------
# Google Gemini AI (Bespoke Design Generator)
# Console: https://aistudio.google.com/apikey
# Docs: https://ai.google.dev/gemini-api/docs
# -----------------------------------------------------------------------------
GEMINI_API_KEY=your-gemini-api-key-here

# -----------------------------------------------------------------------------
# Base URL (used for Stripe redirect URLs, OG tags, etc.)
# Set to your production domain or localhost for development
# -----------------------------------------------------------------------------
NEXT_PUBLIC_BASE_URL=https://www.lkbjewellers.com

# -----------------------------------------------------------------------------
# Email (SMTP via Hostinger)
# Used for sending transactional emails to customers and admin notifications
# s-----------------------------------------------------------------------------
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=noreply@lkbjewellers.com
SMTP_PASS=your-smtp-password-here
ADMIN_EMAIL=noreply@lkbjewellers.com
